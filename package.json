{
  "name": "gog-loader",
  "version": "1.0.1",
  "description": "GOG Library Backup Tool",
  "productName": "GOG Loader",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "cross-env NODE_NO_WARNINGS=1 electron-builder --dir",
    "dist": "cross-env NODE_NO_WARNINGS=1 electron-builder",
    "dist:mac": "cross-env NODE_NO_WARNINGS=1 electron-builder --mac",
    "dist:win": "cross-env NODE_NO_WARNINGS=1 electron-builder --win",
    "dist:linux": "cross-env NODE_NO_WARNINGS=1 electron-builder --linux"
  },
  "author": "",
  "license": "UNLICENSED",
  "build": {
    "appId": "com.gogloader.app",
    "beforeBuild": "./scripts/electron-builder-before-build.js",
    "productName": "GOG Loader",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "icon.png",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "category": "Utility",
      "icon": "icon.png",
      "target": [
        "AppImage",
        "tar.gz"
      ]
    }
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^26.0.12"
  }
}
